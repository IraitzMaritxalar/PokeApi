{
  "compilerOptions": {
    // Entorno y características modernas
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",

    // Carpeta de origen y salida
    "rootDir": "./js",
    "outDir": "./dist",

    // Estricto para TS
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Flags opcionales menos estrictos
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": ["js/**/*.ts"]
}